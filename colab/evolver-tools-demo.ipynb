        "!echo '{\"users\":[{\"name\":\"Alice\",\"role\":\"engineer\",\"skills\":[\"python\",\"go\",\"k8s\"]},{\"name\":\"Bob\",\"role\":\"designer\",\"skills\":[\"figma\",\"css\"]},{\"name\":\"Charlie\",\"role\":\"devops\",\"skills\":[\"aws\",\"terraform\",\"docker\"]}]}' > /tmp/data.json\n",
